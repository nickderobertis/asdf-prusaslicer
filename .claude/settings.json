{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(just bootstrap)",
      "Bash(just format)",
      "Bash(just format-check)",
      "Bash(just lint)",
      "Bash(just lint-fix)",
      "Bash(just test)",
