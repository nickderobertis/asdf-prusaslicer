#!/usr/bin/env bash
#
# Configuration notes, shown by `asdf help prusaslicer`.
set -euo pipefail

cat <<'EOF'
Environment variables (all optional):
  * GITHUB_API_TOKEN  Personal access token used only to raise the GitHub API
                      rate limit (60 requests/hour unauthenticated) when listing
                      versions or resolving a download. Never required for normal
                      use. GITHUB_TOKEN is accepted as a fallback.

Checksums:
  Upstream does not publish per-asset checksums for PrusaSlicer releases, so the
  plugin cannot verify one. Downloads are fetched over HTTPS from GitHub release
  assets and curl fails on any non-success HTTP status.

Versions:
  Prereleases (-alpha/-beta/-rc) are excluded from `list all` and `latest`.
EOF
